# Telegram Bot API token from BotFather
BOT_TOKEN=

# OpenRouter API key
OPENROUTER_API_KEY=

# AI model used through OpenRouter
OPENROUTER_MODEL=openai/gpt-4o-mini

# PostgreSQL connection string
DATABASE_URL=

# Number of recent messages sent to AI as context
AI_HISTORY_LIMIT=10

# AI creativity level: lower = more stable, higher = more creative
AI_TEMPERATURE=0.5

# Maximum AI response length
AI_MAX_TOKENS=500